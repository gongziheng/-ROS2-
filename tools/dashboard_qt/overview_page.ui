    background: #22C55E;
    color: #FFFFFF;
    border: none;
    border-radius: 10px;
    min-height: 38px;
    padding: 0 18px;
    font: 700 10pt "Microsoft YaHei";
}
QPushButton#primaryButton:hover {
    background: #16A34A;
}
QPushButton#secondaryButton {
    background: #F3FAF5;
    color: #168C48;
    border: 1px solid #CDEED8;
    border-radius: 10px;
    min-height: 38px;
    padding: 0 18px;
    font: 700 10pt "Microsoft YaHei";
}
QPushButton#secondaryButton:hover {
    background: #E8F8EE;
}
QTableWidget {
    background: #FFFFFF;
    border: 1px solid #E6EEE8;
    border-radius: 12px;
    gridline-color: #EEF2EF;
    color: #243126;
}
QHeaderView::section {
