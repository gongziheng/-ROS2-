  <property name="styleSheet">
   <string notr="true">QWidget {
    background: #F7FAF7;
    color: #1F2A1F;
    font-family: "Microsoft YaHei", "PingFang SC", "Noto Sans CJK SC", sans-serif;
}
QFrame#pageCard, QFrame#statCard, QFrame#taskCard, QFrame#logCard, QFrame#tableCard, QFrame#settingsCard, QFrame#heroCard {
    background: #FFFFFF;
    border: 1px solid #E6EEE8;
    border-radius: 16px;
}
QLabel#pageHeading {
    color: #16311E;
    font: 700 18pt "Microsoft YaHei";
}
QLabel#pageSubheading {
    color: #6E7E73;
    font: 10pt "Microsoft YaHei";
}
QLabel#sectionTitle {
    color: #203024;
    font: 700 10.5pt "Microsoft YaHei";
}
QLabel#statValue {
    color: #168C48;
    font: 700 18pt "Microsoft YaHei";
}
QLabel#statLabel, QLabel#fieldLabel {
    color: #738377;
    font: 9.5pt "Microsoft YaHei";
}
QLineEdit, QComboBox, QPlainTextEdit, QSpinBox, QDoubleSpinBox {
    background: #FFFFFF;
    border: 1px solid #DCE8DF;
    border-radius: 10px;
    padding: 6px 10px;
    color: #223026;
}
QPushButton#primaryButton {
    background: #22C55E;
    color: #FFFFFF;
    border: none;
    border-radius: 10px;
    min-height: 38px;
    padding: 0 18px;
    font: 700 10pt "Microsoft YaHei";
}
QPushButton#primaryButton:hover {
    background: #16A34A;
}
QPushButton#secondaryButton {
    background: #F3FAF5;
    color: #168C48;
    border: 1px solid #CDEED8;
    border-radius: 10px;
    min-height: 38px;
    padding: 0 18px;
    font: 700 10pt "Microsoft YaHei";
}
QPushButton#secondaryButton:hover {
    background: #E8F8EE;
}
QTableWidget {
    background: #FFFFFF;
    border: 1px solid #E6EEE8;
    border-radius: 12px;
    gridline-color: #EEF2EF;
    color: #243126;
}
QHeaderView::section {
    background: #F8FBF8;
    color: #5D6D62;
    padding: 8px;
    border: none;
    border-bottom: 1px solid #E6EEE8;
    font: 700 9pt "Microsoft YaHei";
}</string>
