  <property name="styleSheet">
   <string notr="true">QMainWindow, QWidget#centralwidget {
    background: #F7FAF7;
    color: #1F2A1F;
    font-family: "Microsoft YaHei", "PingFang SC", "Noto Sans CJK SC", sans-serif;
}
QFrame#titleBar {
    background: #FFFFFF;
    border-bottom: 1px solid #E6EEE8;
}
QFrame#sideBar {
    background: #FFFFFF;
    border-right: 1px solid #E6EEE8;
}
QFrame#contentArea {
    background: #F7FAF7;
}
QFrame#topSummaryBar {
    background: #FFFFFF;
    border: 1px solid #E6EEE8;
    border-radius: 14px;
}
QLabel#appBadge {
    background: #22C55E;
    color: #FFFFFF;
    border-radius: 8px;
    font: 700 12pt "Microsoft YaHei";
}
QLabel#pageTitle {
    color: #16311E;
    font: 700 16pt "Microsoft YaHei";
}
QLabel#pageSubtitle, QLabel#lastSyncLabel {
    color: #6E7E73;
    font: 10pt "Microsoft YaHei";
}
QLabel#connectionPill {
    background: #E8F8EE;
    color: #16A34A;
    border: 1px solid #CDEED8;
    border-radius: 11px;
    padding: 3px 12px;
    font: 700 9pt "Microsoft YaHei";
}
QPushButton#btnWindowMinimize, QPushButton#btnWindowMaximize, QPushButton#btnWindowClose {
    min-width: 46px;
    max-width: 46px;
    min-height: 30px;
    max-height: 30px;
    border: none;
    border-radius: 8px;
    background: transparent;
    color: #4E5E53;
    font: 11pt "Microsoft YaHei";
}
QPushButton#btnWindowMinimize:hover, QPushButton#btnWindowMaximize:hover {
    background: #EEF5F0;
    color: #1F2A1F;
}
QPushButton#btnWindowClose:hover {
    background: #E5484D;
    color: #FFFFFF;
}
QPushButton#btnNavOverview, QPushButton#btnNavTasks, QPushButton#btnNavAlerts, QPushButton#btnNavSettings {
    min-height: 42px;
    text-align: left;
    padding: 0 16px;
    border-radius: 10px;
    border: 1px solid transparent;
    background: transparent;
    color: #405045;
    font: 10.5pt "Microsoft YaHei";
}
QPushButton#btnNavOverview:hover, QPushButton#btnNavTasks:hover, QPushButton#btnNavAlerts:hover, QPushButton#btnNavSettings:hover {
    background: #F3FAF5;
    color: #1B7F45;
}
QPushButton#btnNavOverview:checked, QPushButton#btnNavTasks:checked, QPushButton#btnNavAlerts:checked, QPushButton#btnNavSettings:checked {
    background: #E8F8EE;
    color: #138A46;
    border: 1px solid #CDEED8;
    font: 700 10.5pt "Microsoft YaHei";
}
QFrame#robotCard, QFrame#systemCard {
    background: #FFFFFF;
    border: 1px solid #E6EEE8;
    border-radius: 14px;
}
QLabel#cardTitle {
    color: #203024;
    font: 700 10.5pt "Microsoft YaHei";
}
QLabel#metricTitle {
    color: #728276;
    font: 9pt "Microsoft YaHei";
}
QLabel#metricValue {
    color: #1B7F45;
    font: 700 15pt "Microsoft YaHei";
}
QFrame#stackContainer {
    background: transparent;
    border: none;
}
QStackedWidget#stackedPages {
    background: transparent;
    border: none;
}</string>
